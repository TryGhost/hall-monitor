{
  "name": "hall-monitor",
  "version": "0.1.0",
  "description": "CLI tool that monitors Discourse forums for open-source project maintainers",
  "type": "module",
  "bin": {
    "hall-monitor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.87.0",
    "better-sqlite3": "11.10.0",
    "commander": "13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.19.17",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
